        "import pandas as pd\n",
        "\n",
        "data = [\n",
        "[\"infantil\",\"miopia\",\"não\",\"reduzida\",\"nenhuma\"],\n",
        "[\"infantil\",\"miopia\",\"sim\",\"normal\",\"gelatinosa\"],\n",
        "[\"infantil\",\"hipermetropia\",\"não\",\"normal\",\"gelatinosa\"],\n",
        "[\"infantil\",\"hipermetropia\",\"sim\",\"normal\",\"dura\"],\n",
        "[\"adolescente\",\"miopia\",\"não\",\"reduzida\",\"gelatinosa\"],\n",
        "[\"adolescente\",\"miopia\",\"sim\",\"reduzida\",\"nenhuma\"],\n",
        "[\"adolescente\",\"miopia\",\"não\",\"normal\",\"dura\"],\n",
        "[\"adolescente\",\"hipermetropia\",\"não\",\"reduzida\",\"gelatinosa\"],\n",
        "[\"adolescente\",\"hipermetropia\",\"sim\",\"normal\",\"dura\"],\n",
        "[\"adulto\",\"miopia\",\"não\",\"normal\",\"gelatinosa\"],\n",
        "[\"adulto\",\"miopia\",\"sim\",\"normal\",\"dura\"],\n",
        "[\"adulto\",\"miopia\",\"sim\",\"reduzida\",\"gelatinosa\"],\n",
        "[\"adulto\",\"hipermetropia\",\"não\",\"reduzida\",\"nenhuma\"],\n",
        "[\"adulto\",\"hipermetropia\",\"sim\",\"normal\",\"gelatinosa\"],\n",
        "[\"adulto\",\"hipermetropia\",\"não\",\"normal\",\"gelatinosa\"],\n",
        "]\n",
        "\n",
        "df = pd.DataFrame(data, columns=[\"idade\",\"diagnostico\",\"astigmatismo\",\"lacrimal\",\"classe\"])\n",
        "\n",
        "paciente = [\"infantil\",\"hipermetropia\",\"não\",\"reduzida\"]\n",
        "\n",
        "classes = df[\"classe\"].unique()\n",
        "atributos = [\"idade\",\"diagnostico\",\"astigmatismo\",\"lacrimal\"]\n",
        "\n",
        "resultado = {}\n",
        "expressoes = {}\n",
        "\n",
        "print(\"Probs condicionais de cada hipótese\\n\")\n",
        "\n",
        "for c in classes:\n",
        "    subset = df[df[\"classe\"] == c]\n",
        "\n",
        "    prob = len(subset) / len(df)\n",
        "    expressao = f\"{len(subset)}/{len(df)}\"\n",
        "\n",
        "    for i, attr in enumerate(atributos):\n",
        "        valores = df[attr].unique()\n",
        "        k = len(valores)\n",
        "\n",
        "        count = len(subset[subset[attr] == paciente[i]])\n",
        "\n",
        "        num = count + 1\n",
        "        den = len(subset) + k\n",
        "\n",
        "        prob *= num / den\n",
        "        expressao += f\"*{num}/{den}\"\n",
        "\n",
        "    resultado[c] = prob\n",
        "    expressoes[c] = expressao\n",
        "\n",
        "    print(f\"P[{c.capitalize()}|E] = {expressao} = {prob:.6f}\")\n",
        "\n",
        "print(\"\\nNormalizando as probs\\n\")\n",
        "\n",
        "total = sum(resultado.values())\n",
        "\n",
        "for c in resultado:\n",
        "    normalizado = resultado[c] / total\n",
        "    resultado[c] = normalizado\n",
        "\n",
        "    print(f\"P[{c.capitalize()}|E] = {resultado[c]:.6f}/{total:.6f} = {normalizado*100:.2f}%\")\n",
        "\n",
        "previsao = max(resultado, key=resultado.get)\n",
        "print(f\"\\nA previsão para o exemplo dado seria Lente = {previsao.capitalize()}\")"
      ],
